<Window x:Class="NivelUIWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:NivelUIWPF"
        mc:Ignorable="d"
        Title="Lab 8 - ApartManager"
        Height="600"
        Width="1000"
        MinWidth="700"
        MinHeight="450"
        WindowState="Maximized"
        WindowStyle="ToolWindow"
        Background="#DDEAF6">
    <Window.Resources>
        <Style TargetType="Label">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="#1D3557"/>
        </Style>
        <Style x:Key="MeniuButton" TargetType="Button">
            <Setter Property="Height" Value="40"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="8,0,8,8"/>
            <Setter Property="Background" Value="#1D3557"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
    </Window.Resources>

    <DockPanel Margin="15">
        <!-- meniu vertical pe stanga -->
        <Border DockPanel.Dock="Left"
                Width="170"
                Margin="0,0,15,0"
                Background="#C7DBEC"
                CornerRadius="6">
            <StackPanel>
                <Label Content="Meniu"
                       FontWeight="Bold"
                       FontSize="16"
                       HorizontalAlignment="Center"
                       Margin="0,12,0,15"/>
                <Button x:Name="btnMeniuAdministrare"
                        Content="Administreaza"
                        Style="{StaticResource MeniuButton}"
                        Click="btnMeniuAdministrare_Click"/>
                <Button x:Name="btnMeniuCautare"
                        Content="Cauta"
                        Style="{StaticResource MeniuButton}"
                        Click="btnMeniuCautare_Click"/>
            </StackPanel>
        </Border>

        <!-- zona de continut, schimba intre administrare si cautare -->
        <Grid>
            <!-- PANOU ADMINISTRARE (default vizibil) -->
            <Grid x:Name="pnlAdministrare">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <Label Content="_Numar apartament"
                               Target="{Binding ElementName=txtNumar}"
                               FontWeight="Bold"
                               Padding="0"
                               Margin="0,0,0,6"/>
                        <TextBox x:Name="txtNumar"
                                 Height="30"
                                 FontSize="14"
                                 Padding="8,0"
                                 VerticalContentAlignment="Center"
                                 MaxLength="5"/>
                        <TextBlock x:Name="tbErrNumar"
                                   Text=""
                                   FontSize="11"
                                   Foreground="Red"
                                   Margin="0,4,0,0"
                                   Visibility="Collapsed"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <Label Content="_Etaj"
                               Target="{Binding ElementName=txtEtaj}"
                               FontWeight="Bold"
                               Padding="0"
                               Margin="0,0,0,6"/>
                        <TextBox x:Name="txtEtaj"
                                 Height="30"
                                 FontSize="14"
                                 Padding="8,0"
                                 VerticalContentAlignment="Center"
                                 MaxLength="3"/>
                        <TextBlock x:Name="tbErrEtaj"
                                   Text=""
                                   FontSize="11"
                                   Foreground="Red"
                                   Margin="0,4,0,0"
                                   Visibility="Collapsed"/>
                    </StackPanel>
                </Grid>

                <Grid Grid.Row="1" Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <Label Content="_Suprafata (mp)"
                               Target="{Binding ElementName=txtSuprafata}"
                               FontWeight="Bold"
                               Padding="0"
                               Margin="0,0,0,6"/>
                        <TextBox x:Name="txtSuprafata"
                                 Height="30"
                                 FontSize="14"
                                 Padding="8,0"
                                 VerticalContentAlignment="Center"
                                 MaxLength="6"/>
                        <TextBlock x:Name="tbErrSuprafata"
                                   Text=""
                                   FontSize="11"
                                   Foreground="Red"
                                   Margin="0,4,0,0"
                                   Visibility="Collapsed"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <Label Content="_Pret chirie (lei/luna)"
                               Target="{Binding ElementName=txtPret}"
                               FontWeight="Bold"
                               Padding="0"
                               Margin="0,0,0,6"/>
                        <TextBox x:Name="txtPret"
                                 Height="30"
                                 FontSize="14"
                                 Padding="8,0"
                                 VerticalContentAlignment="Center"
                                 MaxLength="8"/>
                        <TextBlock x:Name="tbErrPret"
                                   Text=""
                                   FontSize="11"
                                   Foreground="Red"
                                   Margin="0,4,0,0"
                                   Visibility="Collapsed"/>
                    </StackPanel>
                </Grid>

                <StackPanel Grid.Row="2" Margin="0,0,0,10">
                    <Label Content="Tip apartament"
                           FontWeight="Bold"
                           Padding="0"
                           Margin="0,0,0,6"/>
                    <WrapPanel>
                        <RadioButton x:Name="rbGarsoniera"
                                     Content="Garsoniera"
                                     GroupName="TipAp"
                                     IsChecked="True"
                                     Margin="0,0,15,5"/>
                        <RadioButton x:Name="rbDouaCamere"
                                     Content="2 camere"
                                     GroupName="TipAp"
                                     Margin="0,0,15,5"/>
                        <RadioButton x:Name="rbTreiCamere"
                                     Content="3 camere"
                                     GroupName="TipAp"
                                     Margin="0,0,15,5"/>
                        <RadioButton x:Name="rbPatruCamere"
                                     Content="4 camere"
                                     GroupName="TipAp"
                                     Margin="0,0,15,5"/>
                        <RadioButton x:Name="rbPenthouse"
                                     Content="Penthouse"
                                     GroupName="TipAp"
                                     Margin="0,0,0,5"/>
                    </WrapPanel>
                </StackPanel>

                <StackPanel Grid.Row="3" Margin="0,0,0,10">
                    <Label Content="Facilitati"
                           FontWeight="Bold"
                           Padding="0"
                           Margin="0,0,0,6"/>
                    <WrapPanel>
                        <CheckBox x:Name="cbBalcon" Content="Balcon" Margin="0,0,15,5"/>
                        <CheckBox x:Name="cbParcare" Content="Parcare" Margin="0,0,15,5"/>
                        <CheckBox x:Name="cbCentrala" Content="Centrala termica" Margin="0,0,15,5"/>
                        <CheckBox x:Name="cbAC" Content="Aer conditionat" Margin="0,0,15,5"/>
                        <CheckBox x:Name="cbLocJoaca" Content="Loc de joaca" Margin="0,0,0,5"/>
                    </WrapPanel>
                </StackPanel>

                <StackPanel Grid.Row="4"
                            Orientation="Horizontal"
                            Margin="0,10,0,10">
                    <Button x:Name="btnSalveaza"
                            Content="_Salveaza Apartament"
                            Width="200"
                            Height="32"
                            Margin="0,0,10,0"
                            Click="btnSalveaza_Click"/>
                    <Button x:Name="btnReseteaza"
                            Content="_Reset"
                            Width="120"
                            Height="32"
                            Click="btnReseteaza_Click"/>
                </StackPanel>

                <Separator Grid.Row="5" Margin="0,5,0,10"/>

                <Grid Grid.Row="6" Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Label Content="Cautare dupa pret maxim:" FontWeight="Bold" Padding="0" VerticalAlignment="Center"/>
                    <TextBox x:Name="txtPretMax"
                             Grid.Column="1"
                             Width="120"
                             Height="28"
                             FontSize="13"
                             Padding="8,0"
                             VerticalContentAlignment="Center"
                             Margin="10,0,10,0"/>
                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                        <Button x:Name="btnCauta" Content="Cauta" Width="90" Height="28" Margin="0,0,8,0" Click="btnCauta_Click"/>
                        <Button x:Name="btnReset" Content="Toate" Width="90" Height="28" Click="btnResetCautare_Click"/>
                    </StackPanel>
                </Grid>

                <!-- COMBOBOX - Filtrare dupa Tip -->
                <Grid Grid.Row="7" Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <Label Content="Filtreaza dupa tip apartament:" FontWeight="Bold" Padding="0" Margin="0,0,0,6"/>
                        <ComboBox x:Name="cbTipApartament" Height="30" Padding="8" FontSize="12">
                            <ComboBoxItem Content="Toate tipurile" IsSelected="True"/>
                            <ComboBoxItem Content="Garsoniera"/>
                            <ComboBoxItem Content="2 camere"/>
                            <ComboBoxItem Content="3 camere"/>
                            <ComboBoxItem Content="4 camere"/>
                            <ComboBoxItem Content="Penthouse"/>
                        </ComboBox>
                    </StackPanel>

                    <!-- LISTBOX - Afisare apartamente cu facilitati -->
                    <StackPanel Grid.Column="2">
                        <Label Content="Apartamente cu facilitati:" FontWeight="Bold" Padding="0" Margin="0,0,0,6"/>
                        <ListBox x:Name="lbApartamenteFacilitati" Height="80" Background="#F9F9F9" BorderBrush="#CCCCCC" FontSize="11" Padding="8"/>
                    </StackPanel>
                </Grid>

                <Label x:Name="lblNrApartamente"
                       Grid.Row="8"
                       FontWeight="Bold"
                       Margin="0,0,0,6"/>

                <DataGrid x:Name="dgApartamente"
                        Grid.Row="9"
                        AutoGenerateColumns="False"
                        IsReadOnly="True"
                        CanUserAddRows="False"
                        CanUserDeleteRows="False"
                        HeadersVisibility="Column"
                        GridLinesVisibility="All"
                        AlternatingRowBackground="#F5F5F5"
                        RowHeight="26">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Numar" Binding="{Binding Numar}" Width="70"/>
                        <DataGridTextColumn Header="Etaj" Binding="{Binding Etaj}" Width="60"/>
                        <DataGridTextColumn Header="Suprafata" Binding="{Binding Suprafata}" Width="80"/>
                        <DataGridTextColumn Header="Pret/luna" Binding="{Binding PretChirie}" Width="90"/>
                        <DataGridTextColumn Header="Chirie an" Binding="{Binding ChirieAnuala}" Width="90"/>
                        <DataGridTextColumn Header="Tip" Binding="{Binding Tip}" Width="100"/>
                        <DataGridTextColumn Header="Facilitati" Binding="{Binding Facilitati}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>

            <!-- PANOU CAUTARE (default ascuns) -->
            <Grid x:Name="pnlCautare" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Label Grid.Row="0"
                       Content="Cautare apartament dupa numar"
                       FontWeight="Bold"
                       FontSize="18"
                       Margin="0,0,0,15"/>

                <Grid Grid.Row="1" Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Label Grid.Column="0"
                           Content="Numar apartament:"
                           FontWeight="Bold"
                           VerticalAlignment="Center"/>
                    <TextBox x:Name="txtCautaNumar"
                             Grid.Column="1"
                             Height="30"
                             FontSize="14"
                             Padding="8,0"
                             VerticalContentAlignment="Center"
                             Margin="10,0,10,0"
                             MaxLength="5"/>
                    <Button x:Name="btnCautaDupaNumar"
                            Grid.Column="2"
                            Content="Cauta"
                            Width="100"
                            Height="30"
                            Click="btnCautaDupaNumar_Click"/>
                </Grid>

                <Label x:Name="lblMesajCautare"
                       Grid.Row="2"
                       Foreground="#A02828"
                       FontWeight="Bold"
                       Margin="0,5,0,10"/>

                <DataGrid x:Name="dgRezultatCautare"
                          Grid.Row="3"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          HeadersVisibility="Column"
                          GridLinesVisibility="All"
                          AlternatingRowBackground="#F5F5F5"
                          RowHeight="26">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Numar" Binding="{Binding Numar}" Width="70"/>
                        <DataGridTextColumn Header="Etaj" Binding="{Binding Etaj}" Width="60"/>
                        <DataGridTextColumn Header="Suprafata" Binding="{Binding Suprafata}" Width="80"/>
                        <DataGridTextColumn Header="Pret/luna" Binding="{Binding PretChirie}" Width="90"/>
                        <DataGridTextColumn Header="Tip" Binding="{Binding Tip}" Width="100"/>
                        <DataGridTextColumn Header="Facilitati" Binding="{Binding Facilitati}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Grid>
    </DockPanel>
</Window>
